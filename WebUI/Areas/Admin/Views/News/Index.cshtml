@model IEnumerable<News>

@{
    ViewData["Title"] = "Haberler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-newspaper me-2"></i>Haber Yönetimi</h1>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-success" id="importBtn" data-bs-toggle="tooltip"
                data-bs-placement="top" title="Excel'den haber aktar">
            <i class="fas fa-file-excel me-2"></i>Excel İçeri Aktar
        </button>
        <a asp-action="Form" class="btn btn-outline-primary" data-bs-toggle="tooltip" data-bs-placement="top"
           title="Yeni duyuru eklemek için tıklayın"><i class="fas fa-circle-plus me-2"></i>Yeni Haber Ekle</a>
        <button type="button" class="btn btn-outline-danger" id="bulkDeleteBtn" data-bs-toggle="tooltip"
                data-bs-placement="top" title="Toplu silme modunu aç/kapat">
            <i class="fas fa-trash-can me-2"></i>Toplu Sil
        </button>
        <button type="button" class="btn btn-outline-danger d-none" id="confirmBulkDeleteBtn">
            <i class="fas fa-check me-2"></i>Seçilenleri Sil
        </button>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-table me-1"></i>
        Haber Listesi
    </div>
    <div class="card-body" style="overflow: visible;">
        <table id="datatablesSimple" class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@Html.DisplayNameFor(model => model.First().Title)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Image)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Status)</th>
                    <th>İşlemler</th>
                    <th class="bulk-check-col" data-sortable="false">
                        <input type="checkbox" id="selectAllCheck"
                               title="Tümünü seç" />
                    </th>
                </tr>
            </thead>
            <tbody>
                @{
                    int index = 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(index++)</td>
                        <td>@Html.DisplayFor(modelItem => item.Title)</td>
                        <td>
                            @{
                                string? imageSrc = ResolveImageSrc(item.Image);
                            }
                            @if (imageSrc != null)
                            {
                                <a href="@imageSrc" target="_blank" data-bs-toggle="tooltip" data-bs-placement="top"
                                       title="Tam boyutta görüntüle">
                                    <img class="table-image" src="@imageSrc" alt="Haber Görseli" loading="lazy" />
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Görsel Yok</span>
                            }
                        </td>
                        <td>
                            @StatusBadge(item.Status)
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"
                                       data-bs-toggle="tooltip" data-bs-placement="top" title="Detaylar">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Form" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"
                                       data-bs-toggle="tooltip" data-bs-placement="top" title="Düzenle">
                                    <i class="fas fa-pen-to-square"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip"
                                        data-bs-placement="top" title="Sil"
                                        onclick="confirmDelete(@item.Id, '@Html.Raw(item.Title.Replace("'", "\\'"))', 'Haberi Sil')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                        <td class="bulk-check-col">
                            <input type="checkbox" class="row-checkbox" value="@item.Id" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteItemId" />
</form>

<form id="bulkDeleteForm" asp-action="BulkDelete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        $('#importBtn').on('click', function () {
            openExcelImportDialog({
                actionUrl: '@Url.Action("ImportExcel")',
                sampleUrl: '@Url.Action("DownloadSampleExcel")',
                requiredFields: ['title'],
                optionalFields: ['description', 'image', 'isactive']
            });
        });
        initBulkDelete('haber');
    </script>
}
@model Brand

@{
    bool isEdit = Model?.Id > 0;
    ViewData["Title"] = isEdit ? "Markayı Düzenle" : "Yeni Marka Ekle";
    Layout = "_AdminLayout";
}

@* breadcrumb ve butonlar *@
<div class="page-header">
    <partial name="~/Areas/Admin/Views/PartialViews/_Breadcrumb.cshtml" model="@ViewBag.Breadcrumbs" />
</div>

<form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    @if (isEdit)
    {
        <input type="hidden" asp-for="Id" />
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

    <div class="row g-3 mb-3">

        <div class="col-lg-6">
            <div class="card border h-100">
                <div class="card-body p-4">
                    <p class="text-uppercase text-muted fw-semibold small mb-3">Temel Bilgiler</p>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium small"></label>
                        <span class="text-danger">*</span>
                        <input asp-for="Name" class="form-control" placeholder="Marka Adı" />
                        <span asp-validation-for="Name" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-medium small"></label>
                        <textarea asp-for="Description" class="form-control" placeholder="Marka hakkında kısa bir açıklama..." rows="4"></textarea>
                        <span asp-validation-for="Description" class="invalid-feedback"></span>
                    </div>

                    <div>
                        <label asp-for="OrderNumber" class="form-label fw-medium small"></label>
                        <input asp-for="OrderNumber" class="form-control" placeholder="0" />
                        <span asp-validation-for="OrderNumber" class="invalid-feedback"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 d-flex flex-column gap-3">

            <div class="card border flex-grow-1">
                <div class="card-body p-4">
                    @await Html.PartialAsync("_ImageUploadWidget", new ImageUploadWidgetViewModel
                    {
                        Label = "Logo",
                                        FieldName = "Logo",
                                        CurrentValue = Model?.Logo,
                                        IsEdit = isEdit
                                        })
                </div>
            </div>

            <div class="card border">
                <div class="card-body p-4">

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label fw-medium small"></label>
                        <span class="text-danger">*</span>
                        <select asp-for="Status" class="form-select">
                            <option value="1">Aktif</option>
                            <option value="2">Pasif</option>
                        </select>
                        <span asp-validation-for="Status" class="invalid-feedback"></span>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2">
            <i class="fas fa-arrow-left"></i> Geri Dön
        </a>
        <button type="submit"
                class="btn @(isEdit ? "btn-outline-success" : "btn-outline-primary") d-flex align-items-center gap-2 fw-semibold">
            <i class="fas fa-circle-check"></i>
            @(isEdit ? "Kaydet" : "Ekle")
        </button>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

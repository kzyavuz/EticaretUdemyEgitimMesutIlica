@model IEnumerable<Brand>

@{
    ViewData["Title"] = "Marka Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">

    <partial name="~/Areas/Admin/Views/PartialViews/_Breadcrumb.cshtml" model="@ViewBag.Breadcrumbs" />

    <div class="button-group">
        <button type="button" class="btn-nx secondary sm" id="importBtn" data-bs-toggle="tooltip"
                data-bs-placement="top" title="Excel'den marka aktar">
            <i class="fas fa-upload"></i>Excel İçeri Aktar
        </button>
        <a asp-action="ExportExcel" class="btn-nx secondary sm" data-bs-toggle="tooltip" data-bs-placement="top"
           title="Markaları Excel olarak indir">
            <i class="fas fa-download"></i>Excel İndir
        </a>
        <a asp-action="Form" class="btn-nx primary" data-bs-toggle="tooltip" data-bs-placement="top"
           title="Yeni marka eklemek için tıklayın">
            <i class="fas fa-plus"></i>Marka Ekle
        </a>
    </div>
</div>

<partial name="_Spinner" />

@* Aktif Paisf verilerin sayısı *@
<partial name="~/Areas/Admin/Views/PartialViews/_StartCard.cshtml" model="@ViewBag.StartCards" />

<div class="card-nx mb-4">

    <div class="bulk-action-bar">
        <span>
            <span class="bulk-count">0</span>
            marka seçildi
        </span>
        <div class="bulk-action-buttons">
            <button class="btn-nx danger-btn sm">
                <i class="fas fa-trash"></i> Sil
            </button>
        </div>
    </div>

    <div class="table-container">
        <table id="dataTable" class="table-nx nowrap" width="100%">
            <thead>
                <tr>
                    <th>#</th>
                    <th>
                        <input type="checkbox" class="check-all checkbox-control" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="Tümünü seç">
                    </th>
                    <th>@Html.DisplayNameFor(model => model.Logo)</th>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.OrderNumber)</th>
                    <th>@Html.DisplayNameFor(model => model.Status)</th>
                    <th>@Html.DisplayNameFor(model => model.CreatedDate)</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int index = 1;
                }
                @foreach (var item in Model)
                {
                    string? logoSrc = ResolveImageSrc(item.Logo);
                    <tr>
                        <td>@(index++)</td>
                        <td>
                            <input type="checkbox" class="row-check checkbox-control" value="@item.Id" data-bs-toggle="tooltip" data-bs-placement="top"
                                   title="Seç">
                        </td>
                        <td>
                            @if (logoSrc != null)
                            {
                                <a href="@logoSrc" target="_blank" data-bs-toggle="tooltip" data-bs-placement="top"
                                   title="Tam boyutta görüntüle" class="table-image-link">
                                    <img class="table-image" src="@logoSrc" alt="Marka Görseli" loading="lazy" />
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@item.Name</td>
                        <td>@item.OrderNumber</td>
                        <td>
                            @Html.Raw(StatusBadge(item.Status))
                        </td>
                        <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <div class="action-btns">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon info"
                                   data-bs-toggle="tooltip" data-bs-placement="top" title="Detaylar">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Form" asp-route-id="@item.Id" class="btn-icon warning"
                                   data-bs-toggle="tooltip" data-bs-placement="top" title="Düzenle">
                                    <i class="fas fa-pen-to-square"></i>
                                </a>
                                <button type="button" class="btn-icon danger" data-bs-toggle="tooltip"
                                        data-bs-placement="top" title="Sil"
                                        onclick="confirmDelete(@item.Id, '@Html.Raw(item.Name.Replace("'", "\\'"))', 'Markayı Sil')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteItemId" />
</form>

<form id="bulkDeleteForm" asp-action="BulkDelete" method="post">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        $(`#importBtn`).on(`click`, function () {
            openExcelImportDialog({
                actionUrl: `@Url.Action("ImportExcel")`,
                sampleUrl: `@Url.Action("DownloadSampleExcel")`,
                requiredFields: [`marka_adi`],
                optionalFields: [`aciklama`, `logo`, `durum`, `sira_numarasi`]
            });
        });
        initBulkDelete(`marka`);
    </script>
}

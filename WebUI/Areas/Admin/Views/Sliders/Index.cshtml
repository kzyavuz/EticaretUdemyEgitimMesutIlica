@model IEnumerable<Slider>

@{
    ViewData["Title"] = "Sliderlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-images me-2"></i>Slider Yönetimi</h1>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-success" id="importBtn" data-bs-toggle="tooltip"
                data-bs-placement="top" title="Excel'den slider aktar">
            <i class="fas fa-file-excel me-2"></i>Excel İçeri Aktar
        </button>
        <a asp-action="Form" class="btn btn-outline-primary" data-bs-toggle="tooltip" data-bs-placement="top"
           title="Yeni slider eklemek için tıklayın"><i class="fas fa-circle-plus me-2"></i>Yeni Slider Ekle</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-table me-1"></i>
        Slider Listesi
    </div>
    <div class="card-body" style="overflow: visible;">
        <table id="datatablesSimple" class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@Html.DisplayNameFor(model => model.First().Title)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Description)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Image)</th>
                    <th>@Html.DisplayNameFor(model => model.First().IsActive)</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int index = 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(index++)</td>
                        <td>@Html.DisplayFor(modelItem => item.Title)</td>
                        <td>@Html.DisplayFor(modelItem => item.Description)</td>

                        <td>
                            @{
                                string? imageSrc = ResolveImageSrc(item.Image);
                            }
                            @if (imageSrc != null)
                            {
                                <a href="@imageSrc" target="_blank" data-bs-toggle="tooltip" data-bs-placement="top"
                                       title="Tam boyutta görüntüle">
                                    <img class="table-image" src="@imageSrc" alt="Slider Görseli" loading="lazy" />
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                @(item.IsActive ? "Evet" : "Hayır")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"
                                   data-bs-toggle="tooltip" data-bs-placement="top" title="Detaylar">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Form" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"
                                   data-bs-toggle="tooltip" data-bs-placement="top" title="Düzenle">
                                <i class="fas fa-pen-to-square"></i>
                            </a>
                            <button type="button" class="mt-1 btn btn-sm btn-outline-danger" data-bs-toggle="tooltip"
                                    data-bs-placement="top" title="Sil"
                                    onclick="confirmDelete(@item.Id, '@Html.Raw(item.Title?.Replace("'", "\\'") ?? "")', 'Slideri Sil')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteItemId" />
</form>

@section Scripts {
    <script>
        $('#importBtn').on('click', function () {
            openExcelImportDialog({
                actionUrl: '@Url.Action("ImportExcel")',
                sampleUrl: '@Url.Action("DownloadSampleExcel")',
                requiredFields: ['title'],
                optionalFields: ['description', 'image', 'link', 'isactive']
            });
        });
    </script>
}
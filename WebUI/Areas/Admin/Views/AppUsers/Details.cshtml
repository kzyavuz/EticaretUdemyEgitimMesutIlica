@model AppUser

@{
    ViewData["Title"] = "Kullanıcı Detayları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var userRoles = ViewBag.UserRoles as IList<string> ?? new List<string>();
    var fullName = ((Model.FirstName ?? "") + " " + (Model.LastName ?? "")).Trim();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-2">
        <div class="bg-primary bg-opacity-10 rounded p-2">
            <i class="fas fa-user text-primary"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-semibold">Kullanıcı Detayları</h4>
            <small class="text-muted">@fullName</small>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Geri Dön
    </a>
</div>

<div class="row g-4">

    <div class="col-lg-8 d-flex flex-column gap-4">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <p class="text-uppercase text-muted fw-semibold small mb-3">Kişisel Bilgiler</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Ad Soyad</span>
                        <strong>@fullName</strong>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Kullanıcı Adı</span>
                        <span>@Model.UserName</span>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted small">E-posta</span>
                        <a href="mailto:@Model.Email">@Model.Email</a>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Telefon</span>
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <a href="tel:@Model.PhoneNumber">@Model.PhoneNumber</a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Durum</span>
                        <span class="badge rounded-pill @(Model.IsActive ? "bg-success" : "bg-danger")">
                            @(Model.IsActive ? "Aktif" : "Pasif")
                        </span>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Oluşturulma</span>
                        <span>@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <p class="text-uppercase text-muted fw-semibold small mb-3">Roller</p>
                @if (userRoles.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var role in userRoles)
                        {
                            <span
                            class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-semibold">@role</span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0"><i class="fas fa-info-circle me-1"></i>Rol atanmamış</p>
                }
            </div>
        </div>

    </div>

    <div class="col-lg-4 d-flex flex-column gap-3">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-center">
                <p class="text-uppercase text-muted fw-semibold small mb-3">Profil Fotoğrafı</p>
                @{
                    string? imageSrc = ResolveImageSrc(Model.Image);
                }
                @if (imageSrc != null)
                {
                    <a href="@imageSrc" target="_blank" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Tam boyutta görüntüle">
                        <img class="rounded-circle ratio-1x1 object-fit-cover" src="@imageSrc" alt="Ürün Görseli"
                             height="100" width="100" loading="lazy" />
                    </a>
                }
                else
                {
                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto"
                         style="width:100px;height:100px">
                        <i class="fas fa-user fa-2x text-muted"></i>
                    </div>
                }
                <p class="fw-semibold mb-0 mt-3">@fullName</p>
                <small class="text-muted">@Model.Email</small>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-grid gap-2">
                <a asp-action="Form" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-pen-to-square me-2"></i>Düzenle
                </a>
                <button type="button" class="btn btn-danger"
                        onclick="confirmDelete(null, '@Html.Raw(fullName.Replace("'", "\\'"))', 'Kullanıcıyı Sil')">
                    <i class="fas fa-trash me-2"></i>Sil
                </button>
            </div>
        </div>

    </div>
</div>

<form id="deleteForm" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>


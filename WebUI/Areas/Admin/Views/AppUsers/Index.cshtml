@model IEnumerable<AppUser>

@{
    ViewData["Title"] = "Kullanżcżlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">

    <partial name="~/Areas/Admin/Views/PartialViews/_Breadcrumb.cshtml" model="@ViewBag.Breadcrumbs" />

    <a asp-action="Form" class="btn-nx primary" data-bs-toggle="tooltip" data-bs-placement="top"
       title="Yeni kullanżcż eklemek iÁin tżklayżn">
        <i class="fas fa-plus"></i>Kullanżcż Ekle
    </a>
</div>

<partial name="_Spinner" />

@* Aktif Paisf verilerin sayżsż *@
<partial name="~/Areas/Admin/Views/PartialViews/_StartCard.cshtml" model="@ViewBag.StartCards" />

<div class="card-nx mb-4">

    <div class="bulk-action-bar">
        <span>
            <span class="bulk-count">0</span>
            marka seÁildi
        </span>
        <div class="bulk-action-buttons">
            <button class="btn-nx danger-btn sm">
                <i class="fas fa-trash"></i> Sil
            </button>
        </div>
    </div>

    <div class="table-container">
        <table id="dataTable" class="table-nx nowrap" width="100%">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@Html.DisplayNameFor(model => model.First().FullName)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Email)</th>
                    <th>@Html.DisplayNameFor(model => model.First().IsActive)</th>
                    <th>Roller</th>
                    <th class="text-end">›Ģlemler</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int index = 1;
                }
                @foreach (var item in Model)
                {
                    string? imageSrc = ResolveImageSrc(item.Image);
                    <tr>
                        <td>@(index++)</td>
                        <td>

                            <div class="product-cell">
                                <div class="product-thumb">
                                    <a href="@imageSrc" target="_blank" data-bs-toggle="tooltip" data-bs-placement="top"
                                       title="Tam boyutta gŲrŁntŁle" class="table-image-link">
                                        <img class="table-image" src="@imageSrc" alt="‹rŁn GŲrseli" loading="lazy" />
                                    </a>
                                </div>
                                <div>
                                    <div class="product-name">@item.FullName</div>
                                    <div class="product-sku">@item.UserName</div>
                                </div>
                            </div>
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                @(item.IsActive ? "Evet" : "Hayżr")
                            </span>
                        </td>
                        <td>
                            @{
                                var userRoles = (ViewBag.UserRoles as Dictionary<int, List<string>>)?[item.Id] ?? new
                                List<string>();
                            }
                            @if (userRoles.Any())
                            {
                                @foreach (var role in userRoles)
                                {
                                    <span class="badge bg-info me-1">@role</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="dt-type-numeric">
                            <div class="action-btns">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon info"
                                   data-bs-toggle="tooltip" data-bs-placement="top" title="Detaylar">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Form" asp-route-id="@item.Id" class="btn-icon warning"
                                   data-bs-toggle="tooltip" data-bs-placement="top" title="DŁzenle">
                                    <i class="fas fa-pen-to-square"></i>
                                </a>
                                <button type="button" class="btn-icon danger" data-bs-toggle="tooltip"
                                        data-bs-placement="top" title="Sil"
                                        onclick="confirmDelete(@item.Id, '@Html.Raw(item.FullName.Replace("'", "\\'"))', 'Kullanżcżyż Sil')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteItemId" />
</form>
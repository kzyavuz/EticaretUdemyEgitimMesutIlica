@model AppUser

@{
    ViewData["Title"] = Model?.Id > 0 ? "Kullanıcıyı Düzenle" : "Yeni Kullanıcı Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    bool isEdit = Model?.Id > 0;
    var roles = (List<Core.Entities.AppRole>?)ViewBag.Roles ?? new List<Core.Entities.AppRole>();
    var userRoles = (IList<string>?)ViewBag.UserRoles ?? new List<string>();
}

<div class="d-flex align-items-center gap-2 mb-4">
    <div class="bg-primary bg-opacity-10 rounded p-2">
        <i class="fas @(isEdit ? "fa-user-pen" : "fa-user-plus") text-primary"></i>
    </div>
    <div>
        <h4 class="mb-0 fw-semibold">@ViewData["Title"]</h4>
        <small class="text-muted">
            @(isEdit ? "Kullanıcı bilgilerini güncelleyin" : "Yeni kullanıcı bilgilerini aşağıya girin")
        </small>
    </div>
</div>

<form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    @if (isEdit)
    {
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Image" />
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

    <div class="row g-3 mb-3">

        <div class="col-lg-6">
            <div class="card border h-100">
                <div class="card-body p-4">
                    <p class="text-uppercase text-muted fw-semibold small mb-3">Kişisel Bilgiler</p>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="FirstName" class="form-label fw-medium small"></label>
                            <span class="text-danger">*</span>
                            <input asp-for="FirstName" class="form-control" placeholder="Ad" />

                            <span asp-validation-for="FirstName" class="invalid-feedback"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="LastName" class="form-label fw-medium small"></label>
                            <span class="text-danger">*</span>
                            <input asp-for="LastName" class="form-control" placeholder="Soyad" />

                            <span asp-validation-for="LastName" class="invalid-feedback"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label fw-medium small"></label>
                        <span class="text-danger">*</span>
                        <input asp-for="UserName" class="form-control" placeholder="kullanici_adi" />

                        <span asp-validation-for="UserName" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium small"></label>
                        <span class="text-danger">*</span>
                        <input asp-for="Email" type="email" class="form-control" placeholder="ornek@mail.com" />

                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    @if (!isEdit)
                    {
                        <div class="mb-3">
                            <label for="password" class="form-label fw-medium small">
                                Şifre <span class="text-danger">*</span>
                            </label>
                            <input type="password" id="password" name="password" class="form-control"
                                   placeholder="••••••••" />
                            <small class="text-muted">
                                En az 8 karakter, büyük/küçük harf, rakam ve özel karakter
                                içermelidir.
                            </small>
                        </div>
                    }

                    <div>
                        <label asp-for="PhoneNumber" class="form-label fw-medium small"></label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="05xx xxx xx xx" />
                        <span asp-validation-for="PhoneNumber" class="invalid-feedback"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 d-flex flex-column gap-3">

            <div class="card border flex-grow-1">
                <div class="card-body p-4">
                    @await Html.PartialAsync("_ImageUploadWidget", new ImageUploadWidgetViewModel
                    {
                        Label = "Profil Fotoğrafı",
                                        FieldName = "Image",
                                        CurrentValue = Model?.Image,
                                        IsEdit = isEdit
                                        })
                </div>
            </div>

            <div class="card border">
                <div class="card-body p-4">
                    <p class="text-uppercase text-muted fw-semibold small mb-3">Durum</p>
                    <div class="d-flex align-items-center gap-3">
                        <div id="toggleSwitch"
                             class="bg-success bg-opacity-25 border border-success rounded-pill position-relative flex-shrink-0 status-toggle-button"
                             role="button">
                            <div data-toggle-thumb class="shadow-sm toggle-thumb status-toggle-button-circle"></div>
                        </div>
                        <div>
                            <p id="toggleLabel" class="mb-0 small fw-semibold">Aktif</p>
                            <p id="toggleSub" class="mb-0 text-muted small">Kullanıcı sisteme giriş yapabilir</p>
                        </div>
                    </div>
                    <input type="checkbox" asp-for="IsActive" id="isActiveCheckbox" class="d-none" />
                </div>
            </div>

            <div class="card border">
                <div class="card-body p-4">
                    <p class="text-uppercase text-muted fw-semibold small mb-3">
                        Roller <span class="text-danger">*</span>
                    </p>
                    <select class="form-select" name="roleIds" multiple size="5">
                        @foreach (var role in roles)
                        {
                            if (userRoles.Contains(role.Name ?? ""))
                            {
                                <option value="@role.Id" selected>@role.Name</option>
                            }
                            else
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                        }
                    </select>
                    <small class="text-muted mt-1 d-block">
                        Ctrl tuşunu basılı tutarak birden fazla rol
                        seçebilirsiniz.
                    </small>
                </div>
            </div>

        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2">
            <i class="fas fa-arrow-left"></i> Geri Dön
        </a>
        <button type="submit"
                class="btn @(isEdit ? "btn-outline-success" : "btn-outline-primary") d-flex align-items-center gap-2 fw-semibold">
            <i class="fas fa-circle-check"></i>
            @(isEdit ? "Kaydet" : "Ekle")
        </button>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            FormUtils.ToggleSwitch.init('toggleSwitch', 'isActiveCheckbox', @(Model?.IsActive.ToString().ToLower() ?? "true"), {
                labelId: 'toggleLabel',
                subId: 'toggleSub',
                activeLabel: 'Aktif',
                inactiveLabel: 'Pasif',
                activeSub: 'Kullanıcı sisteme giriş yapabilir',
                inactiveSub: 'Kullanıcı sisteme giriş yapamaz',
            });
        });
    </script>
}

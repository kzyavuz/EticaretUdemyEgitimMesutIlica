@model IEnumerable<AppRole>

@{
    ViewData["Title"] = "Roller";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-shield-halved me-2"></i>Rol Yönetimi</h1>
    <a asp-action="Form" class="btn btn-outline-primary" data-bs-toggle="tooltip" data-bs-placement="top" title="Yeni rol eklemek için tıklayın">
        <i class="fas fa-circle-plus me-2"></i>Yeni Rol Ekle
    </a>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-table me-1"></i>Rol Listesi
    </div>
    <div class="card-body">
        <table id="datatablesSimple" class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Rol Adı</th>
                    <th>Normalize Ad</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-semibold">
                                <i class="fas fa-shield-halved me-1"></i>@item.Name
                            </span>
                        </td>
                        <td><small class="text-muted">@item.NormalizedName</small></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"
                               data-bs-toggle="tooltip" data-bs-placement="top" title="Detaylar">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Form" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"
                               data-bs-toggle="tooltip" data-bs-placement="top" title="Düzenle">
                                <i class="fas fa-pen-to-square"></i>
                            </a>
                            <button type="button" class="mt-1 btn btn-sm btn-outline-danger"
                                    data-bs-toggle="tooltip" data-bs-placement="top" title="Sil"
                                    onclick="confirmDelete(@item.Id, '@Html.Raw(item.Name?.Replace("'", "\\'"))', 'Rolü Sil')">
                                <i class="fas fa-trash"></i>
                            </button>
                            <form id="deleteForm-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                @Html.AntiForgeryToken()
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

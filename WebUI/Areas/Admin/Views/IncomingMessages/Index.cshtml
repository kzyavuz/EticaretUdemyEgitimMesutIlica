@model IEnumerable<IncomingMessage>

@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    int unreadCount = Model.Count(m => !m.IsRead);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        <i class="fas fa-envelope me-2"></i>Gelen Mesajlar
        @if (unreadCount > 0)
        {
            <span class="badge bg-danger ms-2">@unreadCount okunmadı</span>
        }
    </h1>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-danger" id="bulkDeleteBtn" data-bs-toggle="tooltip"
                data-bs-placement="top" title="Toplu silme modunu aç/kapat">
            <i class="fas fa-trash-can me-2"></i>Toplu Sil
        </button>
        <button type="button" class="btn btn-outline-danger d-none" id="confirmBulkDeleteBtn">
            <i class="fas fa-check me-2"></i>Seçilenleri Sil
        </button>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-table me-1"></i>
        Mesaj Listesi
    </div>
    <div class="card-body">
        <table id="datatablesSimple" class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ad Soyad</th>
                    <th>Email</th>
                    <th>Konu</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                    <th class="bulk-check-col" data-sortable="false"><input type="checkbox" id="selectAllCheck"
                                                                                title="Tümünü seç" /></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr class="@(!item.IsRead ? "fw-bold" : "")">
                            <td>@(index++)</td>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.Subject</td>
                            <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (item.IsRead)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check me-1"></i>Okundu</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="fas fa-envelope me-1"></i>Okunmadı</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"
                                           data-bs-toggle="tooltip" data-bs-placement="top" title="Mesaj\u0131 Oku">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip"
                                            data-bs-placement="top" title="Sil"
                                            onclick="confirmDelete(@item.Id, '@Html.Raw((item.FullName).Replace("'", "\\'"))', 'Mesajı Sil')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                            <td class="bulk-check-col">
                                <input type="checkbox" class="row-checkbox" value="@item.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="deleteItemId" />
    </form>

    <form id="bulkDeleteForm" asp-action="BulkDelete" method="post" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    @section Scripts {
        <script>
            initBulkDelete('mesaj');
        </script>
    }

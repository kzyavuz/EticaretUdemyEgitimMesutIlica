@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <div class="page-breadcrumb">
            <a href="#">Ana Sayfa</a>
            <span class="sep">›</span>
            <span class="current">Dashboard</span>
        </div>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-sm-6 fade-in fade-in-1">
        <div class="stat-card accent">
            <div class="stat-icon gold"><i class="fa-solid fa-dollar-sign"></i></div>
            <div class="stat-value">₺0</div>
            <div class="stat-label">Toplam Gelir</div>
            <div class="stat-change up"><i class="fa-solid fa-arrow-up"></i> Bu Ay</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 fade-in fade-in-2">
        <div class="stat-card success">
            <div class="stat-icon green"><i class="fa-solid fa-cart-shopping"></i></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Toplam Sipariş</div>
            <div class="stat-change up"><i class="fa-solid fa-arrow-up"></i> Bu Ay</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 fade-in fade-in-3">
        <div class="stat-card info">
            <div class="stat-icon blue"><i class="fa-solid fa-users"></i></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Aktif Müşteri</div>
            <div class="stat-change up"><i class="fa-solid fa-arrow-up"></i> Bu Ay</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 fade-in fade-in-4">
        <div class="stat-card danger">
            <div class="stat-icon red"><i class="fa-solid fa-box-open"></i></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Toplam Ürün</div>
            <div class="stat-change down"><i class="fa-solid fa-arrow-down"></i> Stok Takibi</div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card-nx">
            <div class="card-header-nx" style="padding:18px 22px 18px;">
                <h6 style="font-family:'Syne',sans-serif;font-weight:700;font-size:13px;margin:0;letter-spacing:0.04em;text-transform:uppercase;color:var(--text-muted);">Hızlı Erişim</h6>
            </div>
            <div class="card-body-nx" style="padding:0 22px 20px;">
                <div style="display:flex;flex-wrap:wrap;gap:10px;">
                    <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn-nx secondary" style="font-size:13px;">
                        <i class="fa-solid fa-circle-plus" style="color:var(--accent);"></i> Yeni Ürün Ekle
                    </a>
                    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn-nx secondary" style="font-size:13px;">
                        <i class="fa-solid fa-box-open" style="color:var(--info);"></i> Ürün Listesi
                    </a>
                    <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn-nx secondary" style="font-size:13px;">
                        <i class="fa-solid fa-basket-shopping" style="color:var(--success);"></i> Siparişler
                    </a>
                    <a asp-area="Admin" asp-controller="AppUsers" asp-action="Index" class="btn-nx secondary" style="font-size:13px;">
                        <i class="fa-solid fa-users" style="color:var(--warning);"></i> Kullanıcılar
                    </a>
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn-nx secondary" style="font-size:13px;">
                        <i class="fa-solid fa-tags" style="color:var(--accent);"></i> Kategoriler
                    </a>
                    <a asp-area="Admin" asp-controller="IncomingMessages" asp-action="Index" class="btn-nx secondary" style="font-size:13px;">
                        <i class="fa-regular fa-comments" style="color:var(--info);"></i> Mesajlar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Row: Recent Orders + Activity -->
<div class="row g-3">
    <!-- Recent Orders -->
    <div class="col-xl-8">
        <div class="card-nx" style="height:100%;">
            <div class="card-header-nx">
                <h5 style="font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin:0;">Son Siparişler</h5>
                <a asp-area="Admin" asp-controller="Orders" asp-action="Index" style="font-size:12.5px;color:var(--accent);">Tümünü Gör →</a>
            </div>
            <div class="card-body-nx" style="padding:16px 0 0;">
                <div style="overflow-x:auto;">
                    <table class="table-nx" style="min-width:500px;">
                        <thead>
                            <tr>
                                <th>Sipariş No</th>
                                <th>Müşteri</th>
                                <th>Tutar</th>
                                <th>Durum</th>
                                <th>Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="5" style="text-align:center;color:var(--text-muted);padding:32px;">
                                    <i class="fa-solid fa-basket-shopping" style="font-size:24px;display:block;margin-bottom:8px;opacity:0.4;"></i>
                                    Henüz sipariş bulunmuyor
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity -->
    <div class="col-xl-4">
        <div class="card-nx" style="height:100%;">
            <div class="card-header-nx">
                <h5 style="font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin:0;">Son Aktiviteler</h5>
            </div>
            <div class="card-body-nx">
                <div style="display:flex;flex-direction:column;gap:16px;">

                    <div style="display:flex;gap:12px;">
                        <div style="width:8px;height:8px;border-radius:50%;background:var(--success);margin-top:5px;flex-shrink:0;box-shadow:0 0 8px var(--success);"></div>
                        <div>
                            <div style="font-size:13.5px;color:var(--text-primary);">Admin Paneline hoş geldiniz!</div>
                            <div style="font-size:11.5px;color:var(--text-muted);">Şimdi</div>
                        </div>
                    </div>

                    <div style="display:flex;gap:12px;">
                        <div style="width:8px;height:8px;border-radius:50%;background:var(--accent);margin-top:5px;flex-shrink:0;box-shadow:0 0 8px var(--accent-glow);"></div>
                        <div>
                            <div style="font-size:13.5px;color:var(--text-primary);">Nexus Admin v2.5 aktif</div>
                            <div style="font-size:11.5px;color:var(--text-muted);">Tema başarıyla yüklendi</div>
                        </div>
                    </div>

                    <div style="display:flex;gap:12px;">
                        <div style="width:8px;height:8px;border-radius:50%;background:var(--info);margin-top:5px;flex-shrink:0;box-shadow:0 0 8px rgba(59,130,246,0.4);"></div>
                        <div>
                            <div style="font-size:13.5px;color:var(--text-primary);">Ürünler, Siparişler hazır</div>
                            <div style="font-size:11.5px;color:var(--text-muted);">Soldan menüden erişebilirsiniz</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
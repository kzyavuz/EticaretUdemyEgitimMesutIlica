<!DOCTYPE html>
<html lang="tr" data-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Nexus Admin</title>
    <!-- Anti-flicker: tema localStorage'dan anında okunur, render öncesi ayarlanır -->
    <script>
        (function () {
            var theme = localStorage.getItem('nexus-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.2/css/responsive.bootstrap5.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/css/all.min.css" rel="stylesheet" />
    <link href="~/admin/css/admin.css" rel="stylesheet" />
</head>

<body>

    <div class="sidebar-overlay"></div>

    <div class="admin-wrapper">

        <partial name="_SideBar" />

        <div class="main-content">

            <partial name="_TopBar" />

            <main class="content-area">
                @RenderBody()
            </main>

            <partial name="_Footer" />

        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>


    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.2/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.2/js/responsive.bootstrap5.min.js"></script>
    <script src="~/admin/js/admin.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <partial name="~/Views/PartialViews/_Swal2.cshtml" />
    <partial name="_ExcelImportModal" />
</body>

</html>

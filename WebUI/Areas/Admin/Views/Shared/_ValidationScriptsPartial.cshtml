<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
<script>
    // Bootstrap 5 + jQuery Unobtrusive Validation entegrasyonu
    $.validator.setDefaults({
        highlight: function (element) {
            $(element).addClass('is-invalid').removeClass('is-valid');
        },
        unhighlight: function (element) {
            $(element).addClass('is-valid').removeClass('is-invalid');
        }
    });

    // Sunucu tarafı doğrulama hatalarını Bootstrap sınıflarına eşle
    $(function () {
        $('.input-validation-error').addClass('is-invalid');
        if ($('.input-validation-error').length > 0) {
            $('input[data-val], select[data-val], textarea[data-val]').each(function () {
                if (!$(this).hasClass('is-invalid') && $(this).val().trim() !== '') {
                    $(this).addClass('is-valid');
                }
            });
        }
    });
</script>

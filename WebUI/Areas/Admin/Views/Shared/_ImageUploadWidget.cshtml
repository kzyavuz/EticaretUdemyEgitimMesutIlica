@model WebUI.Models.ImageUploadWidgetViewModel

@{
    var prefix        = Model.FieldName;
    var urlInputId    = $"{prefix}UrlInput";
    var urlPreviewId  = $"{prefix}UrlPreview";
    var urlWrapId     = $"{prefix}UrlWrap";
    var fileInputId   = $"{prefix}FileInput";
    var filePreviewId = $"{prefix}FilePreview";
    var fileWrapId    = $"{prefix}FileWrap";
    var dropZoneId    = $"{prefix}DropZone";
    var placeholderId = $"{prefix}Placeholder";
    var urlHiddenId   = $"{prefix}UrlHidden";
    var urlHiddenName = $"{prefix}Url";
    var deleteFlagId  = $"Delete{prefix}";
}

@* Gizli alanlar — form submit için *@
@if (Model.IsEdit)
{
    <input type="hidden" name="@prefix" value="@Model.CurrentValue" />
    <input type="hidden" id="@deleteFlagId" name="@deleteFlagId" value="false" />
}
<input type="hidden" id="@urlHiddenId" name="@urlHiddenName" value="" />

<p class="text-uppercase text-muted fw-semibold small mb-3">@Model.Label</p>

@* Mevcut görsel — sadece düzenleme modunda *@
@if (Model.IsEdit && !string.IsNullOrEmpty(Model.CurrentValue))
{
    <div id="@(prefix)CurrentWrap" class="text-center mb-3">
        <p class="small text-muted mb-1">Mevcut @Model.Label</p>
        <img src="@(Model.CurrentValue.StartsWith("http") ? Model.CurrentValue : $"/{Model.CurrentValue}")"
             class="img-fluid rounded border" style="max-height:120px;" alt="Mevcut @Model.Label" />
        <div class="mt-2">
            <button type="button" class="btn btn-outline-danger btn-sm"
                    onclick="
                        document.getElementById('@deleteFlagId').value='true';
                        document.getElementById('@(prefix)CurrentWrap').classList.add('d-none');
                    ">
                <i class="fas fa-trash-alt me-1"></i> Resmi Kaldır
            </button>
        </div>
    </div>
}

@* URL Bölümü *@
<p class="small fw-semibold mb-1">URL ile Ekle</p>
<div class="input-group mb-2">
    <input type="url" id="@urlInputId" class="form-control"
           placeholder="https://example.com/image.png" />
    <button type="button" class="btn btn-outline-primary"
            onclick="FormUtils.previewImageFromUrl('@urlInputId','@urlPreviewId',null,null,'@urlHiddenId','@urlWrapId')">
        <i class="fas fa-eye me-1"></i> Önizle
    </button>
</div>
<div id="@urlWrapId" class="mb-2 d-none">
    <img id="@urlPreviewId" src=""
         class="img-fluid rounded border d-block mx-auto" style="max-height:120px;" alt="URL Önizleme" />
    <div class="text-center mt-1">
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="FormUtils.clearUrlInput('@urlInputId','@urlPreviewId','@urlWrapId','@urlHiddenId')">
            <i class="fas fa-times me-1"></i> Temizle
        </button>
    </div>
</div>

<div class="d-flex align-items-center gap-2 my-3">
    <hr class="flex-grow-1 m-0" />
    <span class="text-muted small px-2">veya</span>
    <hr class="flex-grow-1 m-0" />
</div>

@* Dosya Yükleme Bölümü *@
<p class="small fw-semibold mb-1">Dosya Yükle</p>
<div id="@dropZoneId"
     class="border border-2 rounded-3 p-3 text-center"
     onclick="document.getElementById('@fileInputId').click()"
     role="button">
    <div id="@placeholderId">
        <i class="fas fa-image fa-2x text-secondary mb-2 d-block"></i>
        <p class="small text-secondary mb-1">Görseli buraya sürükleyin ya da <span class="text-primary">seçin</span></p>
        <p class="small text-muted mb-0">PNG, JPG, SVG — maks. 2 MB</p>
    </div>
</div>
<div id="@fileWrapId" class="mt-2 d-none">
    <img id="@filePreviewId" src=""
         class="img-fluid rounded border d-block mx-auto" style="max-height:120px;" alt="Dosya Önizleme" />
    <div class="text-center mt-1">
        <button type="button" class="btn btn-danger btn-sm"
                onclick="FormUtils.clearFileInput('@fileInputId','@filePreviewId','@fileWrapId','@placeholderId')">
            <i class="fas fa-times me-1"></i> Seçimi Kaldır
        </button>
    </div>
</div>
<input type="file" id="@fileInputId" name="@prefix"
       class="d-none" accept="image/*"
       onchange="FormUtils.previewImage(this,'@filePreviewId','@placeholderId',null,'@fileWrapId')" />

<div class="alert alert-info d-flex align-items-center gap-2 mt-3 mb-0 py-2 small">
    <i class="fas fa-circle-info flex-shrink-0"></i>
    Dosya seçilmişse yüklenen dosya kaydedilecektir.
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        FormUtils.initDropZone('@dropZoneId', '@fileInputId');
    });
</script>

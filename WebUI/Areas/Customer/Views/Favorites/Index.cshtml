@model IEnumerable<Product>

@{
    ViewData["Title"] = "Beğenilen Ürünler";
    Layout = "_CustomerLayout";
}
<div class="cust-page-header cust-page-header-row">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p>Beğendiğiniz ürünler burada listelenmektedir.</p>
    </div>
</div>

<section aria-labelledby="customer-favorites-heading">
    @if (Model == null || !Model.Any())
    {
        <p class="text-center text-muted">Gösterilecek ürün bulunamadı.</p>
    }
    else
    {
        <div class="row g-2 g-md-3">

            @Html.AntiForgeryToken()
            @foreach (Product item in Model)
            {
                <div class="col-6 col-md-4 col-xl-3" data-aos="fade-up">
                    @await Component.InvokeAsync("ProductCard", new { product = item })
                </div>
            }
        </div>
    }
   
</section>


<script>
    (function() {
        // Anahtar isimlerini ana JS dosyanızla (ap2-) eşitledik
        const theme = localStorage.getItem("ap2-theme") || "dark";
        const radius = localStorage.getItem("ap2-radius") || "md";
        const font = localStorage.getItem("ap2-font") || "poppins";

        const root = document.documentElement;

        // Tarayıcı sayfayı çizmeye başlamadan (render) hemen önce öznitelikleri ekliyoruz
        root.setAttribute("data-theme", theme);
        root.setAttribute("data-bs-theme", theme); // Bootstrap 5.3+ desteği için eklendi
        root.setAttribute("data-radius", radius);
        root.setAttribute("data-font", font);

        // CSS yüklenirken transition'ların tetiklenmesini engelle
        root.classList.add("no-transition");
    })();
</script>


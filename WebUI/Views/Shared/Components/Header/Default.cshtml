@section Scripts {
    <script>
        /* ── Auth pill slider ── */
        (function() {
            var group = document.getElementById('authNavGroup');
            var pill = document.getElementById('authPill');
            if (!group || !pill) return;
            var btns = group.querySelectorAll('.btn-nav-login, .btn-nav-register');

            function movePill(btn) {
                pill.style.left = btn.offsetLeft + 'px';
                pill.style.width = btn.offsetWidth + 'px';
                btns.forEach(function(b) {
                    b.classList.remove('auth-active');
                });
                btn.classList.add('auth-active');
            }

            /* Init pill hidden in center — no transition so it appears instantly on first hover */
            pill.style.transition = 'none';
            pill.style.opacity = '0';
            var midBtn = btns[Math.floor(btns.length / 2)];
            pill.style.left = midBtn.offsetLeft + 'px';
            pill.style.width = midBtn.offsetWidth + 'px';

            group.addEventListener('mouseenter', function() {
                /* On first enter: snap pill to hovered btn without animation, then fade + enable transition */
                var hovered = group.querySelector(':hover.btn-nav-login, :hover.btn-nav-register');
                if (!hovered) hovered = btns[0];
                pill.style.left = hovered.offsetLeft + 'px';
                pill.style.width = hovered.offsetWidth + 'px';
                pill.style.opacity = '1';
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        pill.style.transition = '';
                    });
                });
            });

            group.addEventListener('mouseleave', function() {
                /* Hide pill and reset transition state for next entry */
                pill.style.transition = 'none';
                pill.style.opacity = '0';
            });

            btns.forEach(function(btn) {
                btn.addEventListener('mouseenter', function() {
                    movePill(this);
                });
            });
        }());

        /* ── Mega menu – smooth Swiper-feel transition ── */
        (function() {
            var items = Array.prototype.slice.call(document.querySelectorAll('li.has-mega'));
            var activeItem = null;
            var closeTimer = null;

            function idxOf(item) {
                return items.indexOf(item);
            }

            function show(item) {
                clearTimeout(closeTimer);
                var mega = item.querySelector('.nav-mega');
                if (!mega) return;

                if (activeItem && activeItem !== item) {
                    /* Switching: instantly hide previous, slide-in new */
                    var prevMega = activeItem.querySelector('.nav-mega');
                    if (prevMega) {
                        prevMega.classList.remove('is-active', 'from-left', 'from-right');
                    }
                    var dir = idxOf(item) > idxOf(activeItem) ? 'from-right' : 'from-left';
                    mega.classList.remove('from-left', 'from-right');
                    void mega.offsetWidth; /* reflow – restart animation */
                    mega.classList.add('is-active', dir);
                } else {
                    /* First open: fade + slide-up (default CSS transition) */
                    mega.classList.remove('from-left', 'from-right');
                    mega.classList.add('is-active');
                }
                activeItem = item;
            }

            function scheduleClose(item) {
                clearTimeout(closeTimer);
                closeTimer = setTimeout(function() {
                    if (activeItem !== item) return;
                    var mega = item.querySelector('.nav-mega');
                    if (mega) mega.classList.remove('is-active', 'from-left', 'from-right');
                    activeItem = null;
                }, 200);
            }

            items.forEach(function(item) {
                item.addEventListener('mouseenter', function() {
                    show(this);
                });
                item.addEventListener('mouseleave', function() {
                    scheduleClose(this);
                });

                /* Keep panel alive when mouse is inside the mega area */
                var mega = item.querySelector('.nav-mega');
                if (mega) {
                    mega.addEventListener('mouseenter', function() {
                        clearTimeout(closeTimer);
                    });
                    mega.addEventListener('mouseleave', function() {
                        var parent = this.closest('li.has-mega');
                        if (parent) scheduleClose(parent);
                    });
                }
            });
        }());
    </script>
}
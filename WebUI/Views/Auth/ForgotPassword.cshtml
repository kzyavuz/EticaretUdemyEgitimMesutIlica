@model ForgotPasswordViewModel
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Sifremi Unuttum";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="auth-shell">
    <div class="auth-card row g-0">
        <div class="col-lg-5 auth-visual d-none d-lg-flex flex-column justify-content-between">
            <div>
                <div class="brand"><i class="fa-solid fa-shield-halved"></i> Askar Profile</div>
                <h3>Sifirla ve devam et</h3>
                <p>Baglanti e-postana gonderilecek. Gelen kutunu kontrol etmeyi unutma.</p>
                <div class="pill"><i class="fa-solid fa-link"></i> Tek kullanimlik baglanti</div>
            </div>
            <small class="opacity-75">Eger mail gelmediyse spam klasorune de bak.</small>
        </div>
        <div class="col-lg-7 bg-white">
            <div class="auth-form-wrapper">
                <div class="auth-title">Sifremi unuttum</div>
                <div class="auth-subtitle">Hesabina ait e-postayi yaz, sifirlama linki gonderelim.</div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <form asp-action="AForgotPassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="g-recaptcha mb-3" data-sitekey="@Configuration["GoogleReCaptcha:SiteKey"]"></div>
                    <span class="text-danger" id="captchaError"></span>

                    <button type="submit" class="btn btn-primary w-100">Sifirlama baglantisi gonder</button>
                    <div class="text-center mt-3">
                        <a asp-action="SignIn" class="small-link">Giris sayfasina don</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
}
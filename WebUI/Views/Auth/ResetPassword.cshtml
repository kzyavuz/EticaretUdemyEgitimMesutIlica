@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Sifre Sifirla";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="auth-shell">
    <div class="auth-card row g-0">
        <div class="col-lg-5 auth-visual d-none d-lg-flex flex-column justify-content-between">
            <div>
                <div class="brand"><i class="fa-solid fa-shield-halved"></i> Askar Profile</div>
                <h3>Yeni sifre olustur</h3>
                <p>Guclu bir sifre belirleyerek hesabini koru.</p>
                <div class="pill"><i class="fa-solid fa-key"></i> En az 6 karakter</div>
            </div>
            <small class="opacity-75">Bu baglanti tek kullanimlik ve kisa sure gecerlidir.</small>
        </div>
        <div class="col-lg-7 bg-white">
            <div class="auth-form-wrapper">
                <div class="auth-title">Sifre sifirla</div>
                <div class="auth-subtitle">Yeni sifreni belirle ve giris yapmaya devam et.</div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <form asp-action="AResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Sifreyi guncelle</button>
                    <div class="text-center mt-3">
                        <a asp-action="SignIn" class="small-link">Giris sayfasina don</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
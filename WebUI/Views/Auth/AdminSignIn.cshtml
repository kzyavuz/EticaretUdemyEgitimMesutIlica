@model SignInViewModel
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "AdminSignIn";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="auth-page">
    <div class="auth-form-wrap">
        <div class="card p-4">
            
            <div class="auth-panel-grid" aria-hidden="true"></div>
            <div class="auth-panel-orb auth-panel-orb-1" aria-hidden="true"></div>
            <div class="auth-panel-orb auth-panel-orb-2" aria-hidden="true"></div>
            <!-- Kart başlığı -->
            <div class="auth-card-header">
                <div class="auth-card-icon">
                    <i class="fa fa-right-to-bracket" aria-hidden="true"></i>
                </div>
                <div>
                    <h1>Giriş Yap</h1>
                    <p>Admin Panele erişmek için bilgilerinizi giriniz.</p>
                </div>
            </div>

            <!-- Login Formu -->
            <form class="auth-form" method="post" asp-controller="Auth" asp-action="AdminSignIn">

                @Html.AntiForgeryToken()

                <!-- E-posta -->
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <div class="input-icon-wrap">
                        <i class="fa fa-envelope ii-icon" aria-hidden="true"></i>
                        <input type="email"
                               asp-for="Email"
                               class="form-control"
                               placeholder="ornek@sirket.com"
                               autocomplete="email"
                               autofocus />
                        <span class="val"></span>
                    </div>

                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <!-- Şifre -->
                <div class="form-group">
                    <label asp-for="Password"></label>
                    <div class="input-icon-wrap">
                        <i class="fa fa-lock ii-icon" aria-hidden="true"></i>
                        <input type="password"
                               asp-for="Password"
                               class="form-control"
                               placeholder="••••••••"
                               autocomplete="current-password" />

                        <button type="button" class="pw-toggle" id="pwToggle" aria-label="Şifreyi göster/gizle">
                            <i class="fa fa-eye" id="pwToggleIcon" aria-hidden="true"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="auth-check m-0">
                        <input asp-for="RememberMe" class="form-check-input m-0" type="checkbox" />
                        <label class="form-check-label" asp-for="RememberMe">Beni hatirla</label>
                    </div>
                    <a asp-action="ForgotPassword" class="forgot-link m-0">Parolami unuttum</a>
                </div>

                <div class="g-recaptcha mb-3" data-sitekey="@Configuration["GoogleReCaptcha:SiteKey"]"></div>
                <span class="text-danger" id="captchaError"></span>

                <!-- Giriş Butonu -->
                <button type="submit" class="btn-auth">
                    <i class="fa fa-right-to-bracket" aria-hidden="true"></i>
                    Giriş Yap
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
}
